# Force HTTPS and canonical hostname (without www)
# Netlify handles HTTPS automatically; this file handles URL canonicalization

# Sitemap — varianta plural gresita redirectata spre cea corecta (elimina 404)
/sitemaps.xml   /sitemap.xml   301!

# Redirect .html versions to clean URLs (301 permanent for SEO)
/barbati.html              /barbati              301!
/femei.html                /femei                301!
/adictii.html              /adictii              301!
/despre.html               /despre               301!
/contact.html              /contact              301!
/blog.html                 /blog                 301!
/pentru-terapeuti.html     /pentru-terapeuti     301!
/multumesc.html            /multumesc            301!
/intrebari-frecvente.html  /intrebari-frecvente  301!
/index.html                /                     301!

# Clean URL serving (Netlify will serve .html when no extension is requested)
# This is the default Netlify behavior, but explicit for clarity


# Articole blog — pagini statice individuale (200, fara redirect)
/blog/burnout-la-medici   /blog/burnout-la-medici.html   200
/blog/a-fi-tata-dupa-divort   /blog/a-fi-tata-dupa-divort.html   200
/blog/de-ce-faci-tot-bine-si-tot-gresesti   /blog/de-ce-faci-tot-bine-si-tot-gresesti.html   200
/blog/cum-sa-recunosti-ce-simti   /blog/cum-sa-recunosti-ce-simti.html   200

# Note din Cabinet — fiecare episod e pagina statica reala in /nc/
# /note-din-cabinet/6 serveste /nc/6.html (200) cu tot textul in HTML (indexabil)
/note-din-cabinet/:ep   /nc/:ep.html   200
